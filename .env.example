# Google Custom Search JSON API — https://programmablesearchengine.google.com/ и https://developers.google.com/custom-search/v1/overview
GOOGLE_API_KEY=your_api_key_here
GOOGLE_CX=your_search_engine_id_here

# Auth.js (Google OAuth) — https://console.cloud.google.com (OAuth 2.0 Client)
AUTH_SECRET=run__npx_auth_secret__to_generate
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# Polar — оплата платных тарифов. Token: polar.sh → Settings → Developers → New Token.
# server: sandbox для тестов, production для боевого. Product ID тарифов см. lib/polar.ts.
POLAR_ACCESS_TOKEN=polar_oat_xxx
POLAR_SERVER=sandbox
